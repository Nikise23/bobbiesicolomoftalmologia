# Copiá este archivo a .env.local y completá los valores.
# NUNCA commitees .env.local (contiene la API key de desarrollo).

# --- SEO / dominio ---
VITE_SITE_URL=https://www.ejemplo.com.ar

# --- Backend de turnos (API pública colom-bobbiesi) ---
# Base SIN /api/public/v1 (el cliente lo agrega solo).
VITE_API_URL=https://colom-bobbiesi.onrender.com

# API key para llamadas DIRECTAS en desarrollo local (header X-API-Key).
# Solo en .env.local. En producción usá el proxy (ver VITE_USE_API_PROXY).
VITE_PUBLIC_API_KEY=

# En producción: true → las requests van a un proxy same-origin (/api/turnos/*)
# que inyecta la API key server-side, sin exponerla en el bundle.
VITE_USE_API_PROXY=false

# --- Enlaces ---
# Panel interno / sistema de historias clínicas (link "Acceso personal").
VITE_SISTEMA_URL=https://colom-bobbiesi.onrender.com/

# --- Feature flag de turnos online ---
# false → wizard oculto ("Próximamente"), CTAs a WhatsApp.
# true  → wizard activo consumiendo la API real (requiere CORS y API key listos).
VITE_TURNOS_ONLINE=false

# --- WhatsApp ---
# Número SIN el signo +, formato internacional.
VITE_WHATSAPP=5491127156477
VITE_WHATSAPP_MSG=Hola, quiero solicitar un turno en el consultorio oftalmológico Colom · Bobbiesi.

# --- Datos de contacto (también usados en schema.org) ---
VITE_CONSULTORIO_DIRECCION=Muñoz 909, San Miguel
VITE_CONSULTORIO_TELEFONO=+54 11 2715-6477

# --- Mapa embebido de Google Maps (iframe src) ---
VITE_MAPS_EMBED_URL=
